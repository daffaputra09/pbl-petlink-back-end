# Supabase project (NestJS + Supabase JS client)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=

# Required for `npm run seed:default-user` only (Auth Admin API). Get it from Supabase Dashboard → Project Settings → API → service_role (secret). Never commit; never use in the browser or mobile app.
SUPABASE_SERVICE_ROLE_KEY=

# Optional overrides for seed:default-user (defaults shown in scripts/seed-default-user.mjs)
# SEED_DEFAULT_USER_EMAIL=admin@petlink.local
# SEED_DEFAULT_USER_PASSWORD=petlink
# SEED_DEFAULT_PROFILE_NAME=Petlink Default Admin
# SEED_DEFAULT_PROFILE_ROLE=admin

# Auth email (doctor invite) — local Supabase reads these from config.toml [auth.email.smtp]
# For hosted Supabase: Dashboard → Project Settings → Authentication → SMTP Settings
SUPABASE_SITE_URL=http://127.0.0.1:3000
SUPABASE_SMTP_USER=mail.notification.app.service@gmail.com
SUPABASE_SMTP_PASS=
SUPABASE_SMTP_ADMIN_EMAIL=mail.notification.app.service@gmail.com
# Production frontend URL for auth redirects (add to Auth → URL Configuration → Redirect URLs)
# SUPABASE_ADDITIONAL_REDIRECT_URL=https://your-app.example.com/auth/callback

# Optional: default password for all users in `npm run seed:users` (default: petlink)
# SEED_DEFAULT_PASSWORD=petlink

# `npm run seed:pet-types` — fills public.pet_types (Anjing, Kucing, …) via scripts/seed-pet-types.mjs
# `npm run seed:services` — min. 3 services per clinic
# `npm run seed:doctor-schedules` — doctor availability blocks (required for bookable slots)

# Pembayaran Midtrans ditangani langsung oleh app mobile (Flutter), bukan backend Nest/Edge Functions.

# Chat push (Firebase Cloud Messaging)
# Service account JSON (single line) from Firebase Console → Project settings → Service accounts.
FIREBASE_SERVICE_ACCOUNT_JSON=
# Must match public.internal_webhook_config.secret for id = chat_push (after db push).
CHAT_WEBHOOK_SECRET=

# Optional: overrides for `npm run test:auth-login` (defaults match seed above)
# TEST_LOGIN_EMAIL=admin@petlink.local
# TEST_LOGIN_PASSWORD=petlink
